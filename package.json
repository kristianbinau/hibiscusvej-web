{
	"name": "nuxt-app",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "NODE_OPTIONS=--max-old-space-size=4096 nuxt build",
		"dev": "nuxt dev",
		"test": "vitest",
		"generate": "nuxt generate",
		"preview": "nuxt preview",
		"postinstall": "nuxt prepare",
		"db:generate": "nuxt db generate",
		"db:migrate": "nuxt db migrate",
		"format": "oxfmt",
		"lint": "oxlint --type-aware --deny-warnings --fix",
		"types": "nuxi typecheck",
		"update-dependencies": "npx npm-check-updates",
		"backup-database": "npx wrangler d1 export hibiscusvej-web --remote --output=./prod-database.sql",
		"check:format": "oxfmt --check",
		"check:lint": "oxlint --type-aware --deny-warnings",
		"check:types": "nuxi typecheck --noEmit"
	},
	"dependencies": {
		"@block65/webcrypto-web-push": "^1.0.2",
		"@date-fns/utc": "^2.1.1",
		"@internationalized/date": "^3.12.0",
		"@libsql/client": "^0.17.0",
		"@nuxt/content": "^3.12.0",
		"@nuxt/ui": "https://pkg.pr.new/@nuxt/ui@6197",
		"@nuxthub/core": "^0.10.7",
		"@popperjs/core": "^2.11.8",
		"@sentry/nuxt": "^10.43.0",
		"bcryptjs": "^3.0.3",
		"better-sqlite3": "^12.8.0",
		"date-fns": "^4.1.0",
		"drizzle-orm": "^0.45.1",
		"jose": "^6.2.1",
		"nuxt": "^4.4.2",
		"ohash": "^2.0.11",
		"reka-ui": "^2.9.2",
		"uncrypto": "^0.1.3",
		"vue": "latest",
		"vue-router": "latest",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@iconify-json/lucide": "^1.2.98",
		"@iconify-json/material-symbols": "^1.2.62",
		"@iconify-json/mdi": "^1.2.3",
		"@nuxt/test-utils": "^4.0.0",
		"@vue/test-utils": "^2.4.6",
		"drizzle-kit": "^0.31.9",
		"happy-dom": "^20.8.4",
		"oxfmt": "^0.41.0",
		"oxlint": "^1.56.0",
		"oxlint-tsgolint": "^0.17.0",
		"playwright-core": "^1.58.2",
		"typescript": "^5.9.3",
		"vitest": "^4.1.0",
		"vue-tsc": "^3.2.5",
		"wrangler": "^4.74.0"
	},
	"volta": {
		"node": "24.13.0"
	}
